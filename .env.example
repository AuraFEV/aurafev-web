# ==========================================================================
# Aura Fev — environment variables reference
# ==========================================================================
# Copy this file to `.env` for local reference only — this static site has
# no local dotenv loader (there's no server to read it). In production,
# set these as Environment Variables in the Render dashboard (or via
# render.yaml, using `sync: false` for anything secret).
#
# Two groups below. Read the header on each before adding a value.
# ==========================================================================


# --------------------------------------------------------------------------
# PUBLIC — safe to expose in client-side JavaScript.
# scripts/generate-config.js copies exactly these into js/config/config.js
# at build time. See that file's PUBLIC_KEYS list — nothing reaches the
# browser that isn't explicitly whitelisted there.
# --------------------------------------------------------------------------

# Canonical site URL, used in meta tags and structured data.
SITE_URL=https://www.aurafev.com
SITE_NAME=Aura Fev

# Public WhatsApp click-to-chat number (used to build wa.me links).
# Format: country code + number, no spaces, no leading zero, no "+".
WHATSAPP_NUMBER=51938700925

# Base URL of the Laura chat backend (backend/ — a separate Render
# service, see backend/README.md). Also doubles as the future base URL
# for cart/checkout/account/order endpoints once that bigger backend
# exists — see README.md#backend-futuro. Empty = chat widget hides itself.
API_BASE_URL=

# Which card gateway processes Visa/Mastercard: "izipay" or "niubiz".
PAYMENT_CARD_GATEWAY=izipay

# Public identifiers only (never a secret key) for each provider's SDK.
IZIPAY_PUBLIC_KEY=
NIUBIZ_MERCHANT_ID=
PAYPAL_CLIENT_ID=
YAPE_MERCHANT_CODE=
PLIN_MERCHANT_CODE=

# Feature flags — show/hide each payment method without a code change.
ENABLE_PAYMENT_VISA=true
ENABLE_PAYMENT_MASTERCARD=true
ENABLE_PAYMENT_YAPE=true
ENABLE_PAYMENT_PLIN=true
ENABLE_PAYMENT_PAYPAL=false
ENABLE_PAYMENT_IZIPAY=true
ENABLE_PAYMENT_NIUBIZ=false

# Google Analytics 4 measurement ID (leave empty to disable analytics).
GA_MEASUREMENT_ID=


# --------------------------------------------------------------------------
# SERVER-ONLY SECRETS — for the future backend described in
# README.md#future-backend. These must NEVER be added to
# scripts/generate-config.js's PUBLIC_KEYS list or otherwise shipped to
# the browser. They are listed here only so the full picture of what
# this project will eventually need is documented in one place.
# --------------------------------------------------------------------------

# Card gateways
IZIPAY_SECRET_KEY=
NIUBIZ_SECRET_KEY=

# PayPal
PAYPAL_CLIENT_SECRET=

# Wallets
YAPE_API_SECRET=
PLIN_API_SECRET=

# Meta WhatsApp Business (Cloud API) — https://developers.facebook.com/docs/whatsapp
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# Database / auth / email, once those modules exist
DATABASE_URL=
JWT_SECRET=
EMAIL_PROVIDER_API_KEY=
