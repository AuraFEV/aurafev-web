# Backend del asistente Laura — variables de entorno
# En Render, estas se configuran en Settings -> Environment de ESTE
# servicio (el backend), no del sitio estático.

# Secreta. Se obtiene en console.anthropic.com -> API Keys.
ANTHROPIC_API_KEY=

# El dominio del sitio que tiene permiso de llamar a esta API (CORS).
ALLOWED_ORIGIN=https://www.aurafev.com

# Opcional. Por defecto usa Sonnet 5 (buena calidad conversacional).
# Para bajar costo, se puede cambiar a un modelo más económico.
MODEL_ID=claude-sonnet-5

# Puerto local (Render lo asigna solo en producción, esto es para
# pruebas locales).
PORT=3001
